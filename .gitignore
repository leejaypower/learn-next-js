# ──────────────────────────────────────────────
# 모노레포 전역 무시 규칙 (안전망)
# 프로젝트별 세부 규칙은 각 하위 디렉터리의 .gitignore에 위임
# 여기 패턴은 anchored(/)를 쓰지 않아 모든 깊이에 적용됨
# ──────────────────────────────────────────────

# 의존성 (루트 hoisting + 하위 어디든)
node_modules/
.pnp
.pnp.*
.yarn/install-state.gz

# 빌드 산출물
.next/
out/
dist/
build/
coverage/

# 환경 변수 / 비밀값 (예시 파일만 허용)
.env
.env.*
!.env.example

# 로그
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# 에디터 / OS
.DS_Store
.vscode/*
!.vscode/settings.json
.idea/
*.pem

# 배포
.vercel
.env*
